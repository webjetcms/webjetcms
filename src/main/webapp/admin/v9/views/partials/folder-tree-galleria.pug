include ../pug/mixins

<div class="dt-header-row clearfix">
    <div class="row">
        <div class="col-auto">
            <div class="dt-buttons">
                <button class="btn btn-sm buttons-create btn-success buttons-divider" type="button" data-toggle="tooltip modal" data-th-title="\#{button.add}" data-target="#galleryFolderEdit">
                    <span><i class="ti ti-plus"></i></span>
                </button>

                <button class="btn btn-sm buttons-selected buttons-edit btn-warning" data-toggle="tooltip modal" data-th-title="\#{button.edit}" data-target="#galleryFolderEdit">
                    <span><i class="ti ti-pencil"></i></span>
                </button>

                <button class="btn btn-sm buttons-selected buttons-remove btn-danger buttons-divider" data-toggle="tooltip" data-th-title="\#{button.delete}">
                    <span><i class="ti ti-trash"></i></span>
                </button>

                <div class="btn btn-sm custom-control form-switch" data-toggle="tooltip" data-th-title="\#{groupedit.allowDragDrop}">
                    <input type="checkbox" class="form-check-input" id="treeAllowDragDrop" value="true"/>
                    <label class="form-check-label is-icon-arrows-v" for="treeAllowDragDrop"></label>
                </div>

                <button class="btn btn-sm btn-outline-secondary buttons-jstree-settings buttons-right" data-toggle="tooltip" data-th-title="\#{datatables.button.settings.js}">
                    <span><i class="ti ti-adjustments-horizontal"></i></span>
                </button>

                <button class="btn btn-sm btn-outline-secondary buttons-refresh buttons-right" data-toggle="tooltip" data-th-title="\#{datatables.button.reload.js}">
                    <span><i class="ti ti-refresh"></i></span>
                </button>

                <button style="display: none;" class="btn btn-sm btn-outline-secondary buttons-settings" data-toggle="tooltip" data-th-title="\#{datatables.button.settings.js}">
                    <span><i class="ti ti-adjustments-horizontal"></i></span>
                </button>

            </div>
        </div>
    </div>
</div>

<div id="SomStromcek" class="hide-while-loading" data-rest-url="/admin/rest/components/gallery/tree" data-rest-param-name="url">
    <ul>

    </ul>
</div>

+jstreesettings("gallery")
    .form-group.row.DTE_Field_Type_checkbox
        label.col-sm-4.col-form-label [[\#{button.view}]]
        .col-sm-7
          .DTE_Field_InputControl
            .custom-control.form-switch
              input#jstree-settings-showrealname.form-check-input(type='checkbox' name='jstree-settings-showrealname' value='true')
              label.form-check-label(for='jstree-settings-showrealname') [[\#{gallery.jstree.show_real_name}]]
        .col-sm-1.form-group-tooltip
          button.btn.btn-link(type='button' data-toggle='tooltip' data-th-title='\#{gallery.jstree.show_real_name.tooltip}')
            i.ti.ti-info-circle
    .form-group.row.row-hr
        .col-sm-7.offset-sm-4
            hr