{
    "java.configuration.updateBuildConfiguration": "automatic",
    "git.ignoreLimitWarning": true,
    "files.exclude": {
        "**/.classpath": true,
        "**/.project": true,
        "**/.settings": true,
        "**/.factorypath": true
    },
    "markdown.validate.enabled": true,
    "java.compile.nullAnalysis.mode": "automatic",
    "sqltools.useNodeRuntime": true,
    "sqltools.connections": [
        {
            "oracleOptions": {
                "autoCommit": true,
                "lowerCase": false
            },
            "previewLimit": 50,
            "server": "oracle.local",
            "port": 1521,
            "driver": "Oracle",
            "name": "WEBJET2022_WEB",
            "database": "pdb19c",
            "username": "WEBJET2022_WEB",
            "password": "************"
        },
        {
            "previewLimit": 50,
            "server": "postgresql.local",
            "port": 10082,
            "driver": "PostgreSQL",
            "name": "pgsql-cms",
            "database": "postgres",
            "username": "postgres"
        }
    ],
    "gitPrefix.pattern": ".*/(\\d+)-.*",
    "coverage-gutters.coverageBaseDir": "docs/codecoverage-report/",
    "coverage-gutters.coverageReportFileName": 	"docs/codecoverage-report/index.html",

    "spellright.language": [
        "cs_CZ",
        "en_US",
        "sk_SK"
    ],
    "spellright.groupDictionaries": false,
    "spellright.documentTypes": [
        "markdown"
    ],
    "spellright.suggestionsInHints": false,
    "spellright.ignoreRegExpsByClass": {
        "markdown": [ "/\\[[^]*?\\]/g", "/\\([^]*?\\)/g"]
    },
    "files.trimTrailingWhitespace": true,
    "github.copilot.chat.commitMessageGeneration.instructions":[
        {
            "text": "Use conventional commit message format."
        },
        {
            "text": "Use imperative mood."
        },
        {
            "text": "Use present tense."
        },
        {
            "text": "Be concise and clear."
        },
        {
            "text": "Use a maximum of 72 characters."
        },
        {
            "text": "Use a single line."
        },
        {
            "text": "Use a period at the end."
        },
        {
            "text": "Ensure commit messages are relevant to the changes made."
        }
    ],
    "chat.tools.terminal.autoApprove": {
        "git rev-parse": true
    },
    "cSpell.language": "en,sk",
    "cSpell.enabledFileTypes": {
        "*": false,
        "markdown": true
    },
    "cSpell.customDictionaries": {
        "webjetcms": {
            "name": "WebJET CMS",
            "path": "${workspaceFolder}/.vscode/spellright.dict",
            "scope": "user",
            "addWords": true,
        }
    },
    "cSpell.ignoreRegExpList": [
        "/`[^`\\n]+`/g",
        "/```[\\s\\S]*?```/g"
    ],
    "workbench.colorCustomizations": {
        "activityBar.activeBackground": "#fb7c7a",
        "activityBar.background": "#fb7c7a",
        "activityBar.foreground": "#15202b",
        "activityBar.inactiveForeground": "#15202b99",
        "activityBarBadge.background": "#a2fca4",
        "activityBarBadge.foreground": "#15202b",
        "commandCenter.border": "#e7e7e799",
        "sash.hoverBorder": "#fb7c7a",
        "statusBar.background": "#f94b49",
        "statusBar.foreground": "#e7e7e7",
        "statusBarItem.hoverBackground": "#fb7c7a",
        "statusBarItem.remoteBackground": "#f94b49",
        "statusBarItem.remoteForeground": "#e7e7e7",
        "titleBar.activeBackground": "#f94b49",
        "titleBar.activeForeground": "#e7e7e7",
        "titleBar.inactiveBackground": "#f94b4999",
        "titleBar.inactiveForeground": "#e7e7e799"
    },
    "peacock.color": "#f94b49",
}