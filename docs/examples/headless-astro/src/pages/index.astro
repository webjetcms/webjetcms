---
import { getNavigation } from '../lib/api';
import Layout from '../layouts/Layout.astro';

const navResult = await getNavigation(Astro.request, '/', undefined, 3);
const nav = navResult.data;

// Forward Set-Cookie headers to the browser
const setCookie = navResult.headers.get('set-cookie');
if (setCookie) {
  Astro.response.headers.append('Set-Cookie', setCookie);
}

const topItems = nav.slice(0, 8);
---

<Layout title="WebJET CMS — Headless Demo" navItems={nav} currentPath="/">
  <div class="welcome-hero">
    <span class="badge">Headless CMS</span>
    <h1>WebJET CMS<br />Headless Integration</h1>
    <p>
      This is a proof-of-concept demonstrating WebJET CMS as a headless backend.
      Content is served via REST API and rendered by this Astro application.
      Use the navigation on the left or search to explore pages.
    </p>
  </div>

  {topItems.length > 0 && (
    <div class="welcome-links">
      {topItems.map((item: any) => (
        <a href={item.virtualPath} class="welcome-link-card">
          <div class="card-title">{item.title}</div>
          <div class="card-path">{item.virtualPath}</div>
        </a>
      ))}
    </div>
  )}
</Layout>
