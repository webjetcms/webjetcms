---
import { getPage, getNavigation } from '../lib/api';
import '../styles/navigation.css';

const pathFromUrl = Astro.url.pathname || '/';
const pathFromQuery = Astro.url.searchParams.get('path');
const apiPath = pathFromQuery
  ? (pathFromQuery.startsWith('/') ? pathFromQuery : `/${pathFromQuery}`)
  : pathFromUrl;

let page = null;
let error = '';

try {
  page = await getPage(apiPath);
} catch (e: unknown) {
  error = e instanceof Error ? e.message : 'Unknown error';
}

const nav = await getNavigation(apiPath, undefined, 2);

// Build nested navigation HTML with expand/collapse
function buildNavHtml(items: any[], level: number): string {
  if (!items || items.length === 0) return '';

  const tag = level === 0 ? 'ul' : 'ul';
  const className = level === 0 ? 'nav-main' : 'nav-children';

  let html = `<${tag} class="${className}">`;

  for (const item of items) {
    const hasChildren = item.children && item.children.length > 0;
    const href = item.virtualPath ? `href="${item.virtualPath}"` : '';

    html += `<li class="nav-item${hasChildren ? ' has-children' : ''}">`;
    html += `<a href="${item.virtualPath}" class="nav-link"${href ? '' : ' style="pointer-events:none;"'}>`;
    html += item.title;
    if (hasChildren) {
      html += ' <span class="nav-toggle">+</span>';
    }
    html += '</a>';

    if (hasChildren) {
      html += buildNavHtml(item.children, level + 1);
    }

    html += '</li>';
  }

  html += `</${tag}>`;
  return html;
}

const navHtml = nav ? buildNavHtml(nav, 0) : '';

// Build content HTML with body embedded directly
const contentHtml = error
  ? `<div class="error"><strong>Error:</strong> ${error}</div>`
  : page
    ? `<div class="content"><h1>${page.title}</h1><p>Path: ${page.virtualPath} | Language: ${page.language}</p>${page.body}</div>`
    : `<p>Enter a path: <code>/:path</code></p>`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{page?.title || 'Headless CMS Demo'}</title>
  <style>
    body { font-family: system-ui, sans-serif; max-width: 900px; margin: 0 auto; padding: 20px; }
  </style>
</head>
<body>
  <h1>WebJET CMS Headless Demo</h1>

  <nav set:html={navHtml}>
  </nav>
  {error ? (
    <div class="error"><strong>Error:</strong> {error}</div>
  ) : page ? (
    <div class="content">
      <h1>{page.title}</h1>
      <p>Path: {page.virtualPath} | Language: {page.language}</p>
      <div set:html={page.body}></div>
    </div>
  ) : (
    <p>Enter a path: <code>/:path</code></p>
  )}

  <script is:inline>
    // Handle expand/collapse for nested menu items
    document.querySelectorAll('.nav-toggle').forEach(function(toggle) {
      toggle.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        var parentLi = this.closest('.has-children');
        var childrenUl = parentLi.querySelector('.nav-children');
        if (childrenUl) {
          var isExpanded = childrenUl.classList.contains('expanded');
          childrenUl.classList.toggle('expanded');
          this.textContent = isExpanded ? '+' : '-';
        }
      });
    });
  </script>
</body>
</html>
