---
import { searchWithHeaders } from '../lib/api';
import '../styles/navigation.css';

const query = Astro.url.searchParams.get('q') || '';
const pageNum = parseInt(Astro.url.searchParams.get('page') || '0', 10) || 0;
const pageSize = 20;

let results: any = { items: [], page: 0, size: pageSize, totalElements: 0, totalPages: 0 };
let searchError = '';

if (query.trim().length > 0) {
  try {
    const searchResult = await searchWithHeaders(query.trim(), Astro.request, pageNum, pageSize);
    results = searchResult.data;

    // Forward Set-Cookie headers to the browser
    const setCookie = searchResult.headers.get('set-cookie');
    if (setCookie) {
      Astro.response.headers.append('Set-Cookie', setCookie);
    }
  } catch (e: unknown) {
    searchError = e instanceof Error ? e.message : 'Search failed';
  }
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{query ? `Search: ${query}` : 'Search Results'} - Headless CMS Demo</title>
  <style>
    body { font-family: system-ui, sans-serif; max-width: 900px; margin: 0 auto; padding: 20px; }
    nav { background: #f5f5f5; padding: 15px; border-radius: 8px; margin-bottom: 20px; }
    nav a { display: block; padding: 5px 0; color: #0066cc; text-decoration: none; }
    nav a:hover { text-decoration: underline; }
    .search-form { margin-top: 12px; display: flex; gap: 8px; }
    .search-form input[type="text"] {
      flex: 1; padding: 8px 12px; border: 1px solid #ccc; border-radius: 4px; font-size: 14px;
    }
    .search-form button {
      padding: 8px 12px; background: #0066cc; color: #fff; border: none; border-radius: 4px;
      cursor: pointer; font-size: 14px;
    }
    .search-form button:hover { background: #0055aa; }
    .search-results { margin-top: 20px; }
    .search-results h2 { margin-bottom: 12px; }
    .result-item {
      padding: 12px 16px; border: 1px solid #e0e0e0; border-radius: 6px; margin-bottom: 12px;
      background: #fafafa;
    }
    .result-item a { color: #0066cc; text-decoration: none; font-weight: 500; }
    .result-item a:hover { text-decoration: underline; }
    .result-snippet {
      margin-top: 6px; font-size: 14px; color: #555; line-height: 1.5;
    }
    .result-meta { font-size: 12px; color: #888; margin-top: 4px; }
    .no-results { padding: 20px; text-align: center; color: #888; }
    .error { color: #c0392b; padding: 12px; background: #fdecea; border-radius: 6px; margin-bottom: 16px; }
    .pagination { display: flex; gap: 8px; margin-top: 16px; }
    .pagination a, .pagination span {
      padding: 6px 12px; border: 1px solid #ccc; border-radius: 4px; text-decoration: none; color: #0066cc;
    }
    .pagination span.disabled { color: #aaa; border-color: #e0e0e0; cursor: default; }
  </style>
</head>
<body>
  <h1>WebJET CMS Headless Demo</h1>

  <nav>
    <form class="search-form" action="/search" method="get">
      <input type="text" name="q" value={query} placeholder="Search documents..." aria-label="Search" />
      <button type="submit">Search</button>
    </form>
  </nav>

  <main class="search-results">
    {searchError ? (
      <div class="error"><strong>Error:</strong> {searchError}</div>
    ) : (
      <>
        {query.trim().length === 0 ? (
          <p>Enter a search term above to find documents.</p>
        ) : results.items && results.items.length > 0 ? (
          <>
            <h2>
              {results.totalResults} result{results.totalResults !== 1 ? 's' : ''} for "{query}"
            </h2>
            {results.items.map((item: any) => (
              <div class="result-item">
                <a href={item.virtualPath}>{item.title}</a>
                {item.language ? <span class="result-meta"> | {item.language}</span> : null}
                {item.virtualPath ? <span class="result-meta"> | {item.virtualPath}</span> : null}
                {item.perex ? (
                  <div class="result-snippet">{item.perex}</div>
                ) : null}
                {item.snippet ? (
                  <div class="result-snippet">{item.snippet}</div>
                ) : null}
              </div>
            ))}
            {results.totalPages > 1 ? (
              <div class="pagination">
                {results.page > 0 ? (
                  <a href={`/search?q=${encodeURIComponent(query)}&page=${results.page - 1}`}>
                    &laquo; Previous
                  </a>
                ) : (
                  <span class="disabled">&laquo; Previous</span>
                )}
                <span>Page {results.page + 1} of {results.totalPages}</span>
                {results.page < results.totalPages - 1 ? (
                  <a href={`/search?q=${encodeURIComponent(query)}&page=${results.page + 1}`}>
                    Next &raquo;
                  </a>
                ) : (
                  <span class="disabled">Next &raquo;</span>
                )}
              </div>
            ) : null}
          </>
        ) : (
          <div class="no-results">
            <p>No results found for "<strong>{query}</strong>".</p>
          </div>
        )}
      </>
    )}
  </main>
</body>
</html>
